# Must match CHAT_API_SECRET. Adds a small barrier for dev use, but should be replaced by real auth in production.
NEXT_PUBLIC_CHAT_API_SECRET=

CHAT_API_SECRET=
GOOGLE_GENERATIVE_AI_API_KEY=AI...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Enables AI SDK OpenTelemetry spans for POST /api/chat when an OpenTelemetry provider/exporter is configured.
# Prompts and outputs are not recorded by this app's telemetry settings.
AI_TELEMETRY_ENABLED=false

# Langfuse (OpenTelemetry export). Keys are issued from the Langfuse project settings. Do not commit real values.
# With AI_TELEMETRY_ENABLED=true, instrumentation registers a NodeTracerProvider using LangfuseSpanProcessor.
# Example hosts: https://cloud.langfuse.com (EU), https://us.cloud.langfuse.com (US)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
